# 이 파일을 복사해서 ".env"로 만들고 값을 채운다.  cp .env.example .env
# 주의: .env 는 절대 git에 올리지 말 것 (진짜 키가 들어감)

# ===== [프록시만 보유] 진짜 프로바이더 키 + 관리자 마스터키 =====
SANITY_LITELLM_MASTER_KEY=sk-sanity-master-CHANGE-ME   # 마스터키(선불카드 발급용). 아무 문자열이나 강한 값으로
# --- 현재 전 에이전트 = Ollama Cloud Gemma (config.yaml 참조) ---
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1            # Ollama Cloud OpenAI 호환 엔드포인트
OLLAMA_CLOUD_API_KEY=<OLLAMA_CLOUD_KEY>                # https://ollama.com 계정 API 키(베어러)
# --- (선택) 폴백/기타 ---
ANTHROPIC_API_KEY=                                     # (선택) Claude로 품질 비교 실험 시
OPENAI_API_KEY=sk-CHANGE-ME                            # (선택) OpenAI 호환 폴백용
OPENAI_BASE_URL=https://openrouter.ai/api/v1           # (선택) 폴백 주소
OLLAMA_BASE_URL=http://localhost:11434                 # (선택) 로컬 Ollama

# ===== [에이전트/클라이언트가 보유] 창구 주소 + 가상키 =====
# LITELLM_API_BASE 는 창구(프록시) 주소. LITELLM_API_KEY 는 선불카드(가상키).
# 가상키는 아래처럼 발급받아 채운다:
#   curl -s http://localhost:4000/key/generate \
#     -H "Authorization: Bearer $SANITY_LITELLM_MASTER_KEY" \
#     -H "Content-Type: application/json" \
#     -d '{"key_alias":"tree3.attacker","max_budget":25,"models":["sane-sonnet","sane-haiku"]}'
LITELLM_API_BASE=http://localhost:4000
LITELLM_API_KEY=sk-sanity-virtual-CHANGE-ME

# ===== 로그 저장 폴더 =====
SANITY_LOG_DIR=./logs
