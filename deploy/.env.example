# deploy/.env.example — `cp .env.example .env` 후 값을 채운다.
# ⚠ 진짜 프로바이더 키(ANTHROPIC/OPENAI)는 gateway(LiteLLM 프록시) 컨테이너에만 주입된다.
#   Attacker/Defender/Scenario-Manager 이미지에는 절대 주입하지 않는다(SR-STACK-02) —
#   그들은 Allocator 가 발급한 가상키(virtual_key)만 사용한다.

# LiteLLM 관리(admin) 마스터키 — SM/Allocator 의 issue_key(가상키 발급)와 gateway 부팅에 필요.
SANITY_LITELLM_MASTER_KEY=sk-sanity-master-change-me

# 프로바이더 키(예선: gateway 컨테이너 전용). 값이 없으면 해당 프로바이더 라우팅만 비활성.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://host.docker.internal:11434
