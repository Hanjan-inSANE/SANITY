{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dah.local/toolset/schemas/tool_result.schema.json",
  "title": "Toolset Common Tool Result",
  "type": "object",
  "required": ["ok", "trace_id", "tool_id", "status", "artifact_refs", "summary", "diagnostics"],
  "properties": {
    "ok": {"type": "boolean"},
    "trace_id": {"type": "string", "minLength": 1},
    "tool_id": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["success", "failure", "timeout", "missing", "skipped"]
    },
    "artifact_refs": {
      "type": "array",
      "items": {"type": "string", "pattern": "^artifact://"}
    },
    "summary": {"type": "string"},
    "diagnostics": {
      "type": "object",
      "properties": {
        "exit_code": {"type": ["integer", "null"]},
        "duration_ms": {"type": "integer", "minimum": 0},
        "stdout_ref": {"type": ["string", "null"]},
        "stderr_ref": {"type": ["string", "null"]},
        "error_type": {"type": "string"},
        "error_message": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
